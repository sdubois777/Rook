{
  "manifest_version": 3,
  "name": "Rook",
  "version": "1.0.0",
  "description": "AI-powered fantasy draft assistant",

  "permissions": [
    "storage",
    "cookies",
    "tabs",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://*.yahoo.com/*",
    "https://*.espn.com/*",
    "https://*.sleeper.com/*",
    "https://*.sleeper.app/*",
    "https://fantasymanager-production.up.railway.app/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://football.fantasysports.yahoo.com/draftclient/*",
        "https://football.fantasysports.yahoo.com/*/draft*"
      ],
      "js": ["yahoo_draft_main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://football.fantasysports.yahoo.com/draftclient/*",
        "https://football.fantasysports.yahoo.com/*/draft*"
      ],
      "js": ["yahoo_draft.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://football.fantasysports.yahoo.com/draftclient/*",
        "https://football.fantasysports.yahoo.com/*/draft*"
      ],
      "js": ["yahoo_snake_draft_main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://football.fantasysports.yahoo.com/draftclient/*",
        "https://football.fantasysports.yahoo.com/*/draft*"
      ],
      "js": ["yahoo_snake_draft.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://football.fantasysports.yahoo.com/*"
      ],
      "js": ["yahoo_auth.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://sports.yahoo.com/fantasy/*"
      ],
      "js": ["yahoo_auth.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://fantasy.espn.com/football/draft*"
      ],
      "js": ["espn_draft.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://fantasy.espn.com/*",
        "https://www.espn.com/fantasy/*"
      ],
      "js": ["espn_auth.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://sleeper.com/draft/*",
        "https://sleeper.app/draft/*"
      ],
      "js": ["sleeper_draft_main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://sleeper.com/draft/*",
        "https://sleeper.app/draft/*"
      ],
      "js": ["sleeper_draft.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "draftmind@fantasymanager",
      "strict_min_version": "109.0"
    }
  }
}
