  "nomination": {
    "raw_payload": "{\"type\": \"nomination\", \"player_id\": \"30977\", \"player_name\": \"Patrick Mahomes\", \"position\": \"QB\", \"nominated_by\": \"Team Alpha\", \"clock_seconds\": 30, \"starting_bid\": 1}",
    "expected_parsed": {
      "type": "nomination",
      "player_id": "30977",
      "player_name": "Patrick Mahomes",
      "nominated_by": "Team Alpha",
      "clock_seconds": 30
    }
  },

  "bid_update": {
    "raw_payload": "{\"type\": \"bid_update\", \"player_id\": \"30977\", \"current_bid\": 45, \"current_bidder\": \"Team Beta\"}",
    "expected_parsed": {
      "type": "bid_update",
      "current_bid": 45,
      "current_bidder": "Team Beta"
    }
  },

  "draft_pick": {
    "raw_payload": "{\"type\": \"draft_pick\", \"player_id\": \"30977\", \"player_name\": \"Patrick Mahomes\", \"team_id\": \"t.5\", \"final_price\": 52}",
    "expected_parsed": {
      "type": "draft_pick",
      "player_id": "30977",
      "team_id": "t.5",
      "final_price": 52
    }
  },

  "clock_warning": {
    "raw_payload": "{\"type\": \"clock_warning\", \"seconds_remaining\": 5}",
    "expected_parsed": {
      "type": "clock_warning",
      "seconds_remaining": 5
    }
  },

  "clock_expired": {
    "raw_payload": "{\"type\": \"clock_expired\", \"player_id\": \"30977\"}",
