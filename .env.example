# Anthropic — required for all AI agents
ANTHROPIC_API_KEY=

# Yahoo Fantasy API (OAuth 2.0)
# 1. Create account at developer.yahoo.com
# 2. Register app with Fantasy Sports scope
# 3. Copy client ID and secret here
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=http://localhost:8000/auth/yahoo/callback
YAHOO_LEAGUE_ID=          # Found in your league URL: football.fantasysports.yahoo.com/f1/LEAGUE_ID
YAHOO_REFRESH_TOKEN=      # Populated automatically after first OAuth flow

# Database — PostgreSQL 16 with pgvector extension
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/fantasy_football

# App
SECRET_KEY=               # Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENVIRONMENT=development   # or: production

# Optional — RapidAPI for supplemental NFL data endpoints
RAPIDAPI_KEY=
