# Anthropic — required for all AI agents
ANTHROPIC_API_KEY=

# Yahoo Fantasy API (OAuth 2.0)
# 1. Create account at developer.yahoo.com
# 2. Register app with Fantasy Sports scope
# 3. Copy client ID and secret here
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=http://localhost:8000/auth/yahoo/callback
YAHOO_LEAGUE_ID=          # Found in your league URL: football.fantasysports.yahoo.com/f1/LEAGUE_ID
YAHOO_REFRESH_TOKEN=      # Populated automatically after first OAuth flow

# Database — PostgreSQL 16 with pgvector extension
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/fantasy_football

# App
SECRET_KEY=               # Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENVIRONMENT=development   # or: production
# Comma-separated admin emails allowed to reach the operator-only pipeline + admin
# routers. FAIL-CLOSED: if empty, all pipeline/admin HTTP routes 403 (CLI still works).
ADMIN_EMAILS=

# Optional — RapidAPI for supplemental NFL data endpoints
RAPIDAPI_KEY=

# Platform credential encryption (Fernet key)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PLATFORM_TOKEN_ENCRYPTION_KEY=

# Public app URL (ESPN bookmarklet redirect target)
APP_URL=http://localhost:8000

# Clerk authentication — required in production, optional in development
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# Stripe billing — server-only (never committed; Railway env vars in prod).
# Use test-mode keys/prices in dev (sk_test_… / whsec_… + test-mode price ids).
# The code is mode-agnostic: only these values differ between test and live.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Local-dev ONLY escape hatch: accept an UNSIGNED webhook (no Stripe-Signature)
# without verification. Leave UNSET/false everywhere. A present signature is always
# verified; this only relaxes the missing-signature case, and only when
# ENVIRONMENT != production. Never set in any deployed environment.
STRIPE_ALLOW_UNVERIFIED_WEBHOOKS=false
# Subscription price ids (recurring monthly) — from scripts/stripe_seed_test.py
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_SEASON=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_SEASON=
# Credit-pack price ids (one-time) — one per CREDIT_PACKS entry in user.py
STRIPE_PRICE_PACK_100=
STRIPE_PRICE_PACK_200=
STRIPE_PRICE_PACK_500=

# Optional — in-season data APIs (Stage 20+)
THE_ODDS_API_KEY=
OPENWEATHERMAP_API_KEY=
